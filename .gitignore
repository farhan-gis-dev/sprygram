# Sprygram .gitignore

# Dependencies
node_modules/
**/node_modules/

# Next.js build output
frontend/.next/
frontend/out/

# TypeScript build info
*.tsbuildinfo
frontend/next-env.d.ts

# Environment / Secrets
.env
.env.*
!.env.example
!.env.sample
frontend/.env
frontend/.env.*
!frontend/.env.example

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dev.log
frontend/dev.log

# OS / Editor
.DS_Store
Thumbs.db
Desktop.ini
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/Release/

# Test and Coverage
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# Package manager caches
.npm/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Misc caches
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tgz
*.pid
*.pid.lock